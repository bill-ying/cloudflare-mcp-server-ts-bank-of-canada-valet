{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Wrangler (workerd)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/.wrangler/**"
      ],
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
